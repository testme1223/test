  end
end   


2.


print "Enter radius of the circle: "
n= gets.chomp.to_i  

puts "parameter of the circle : #{(2*Math::PI*n).round(2)}"
 puts "area of the circle : #{(Math::PI*(n**2)).round(2)}"

3.

print " Enter first name: "
fname = gets.chomp
print " Enter last name: "
lname = gets.chomp

name = fname +" " + lname

print "Full Name : \n",name

words = name.split(" ")

reverse = words.reverse.join(" ")

puts "Reversed name : #{reverse}"

reversed_name = words.map{|words|words.reverse}.join(" ")
print "reversed_name : #{reversed_name}\n"

reverse_full = name.reverse
print "Reversed :  #{reverse_full}"



4.

print " Enter file name: "
fn = gets.chomp

if File.exist?(fn)
  full_path = File.expand_path(fn)
  puts "File exist at #{full_path}"

  ex=File.extname(fn)

  if ex == ""
    puts "no extension found"
  else
    puts "file extension  : ",ex
  end
end



5.


print "Enter a: "
a= gets.chomp.to_i   
print "Enter b: "
b= gets.chomp.to_i   
print "Enter c: "
c= gets.chomp.to_i   
  
if a>b and a>c
  	 puts "greatest number is: #{a} "   
elsif  b>c   
	puts "greatest number is: #{b} "  
else 
  puts "greatest number is: #{c} "   
end


6.


print "Enter the number from which you want odd numbers : "
n = gets.chomp.to_i

while n>0
	if n%2 != 0
		print n," "
	end
	n -= 1

end

