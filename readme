def bfs(graph,s):

    queue = [s]
    visited = set()
    visited.add(s)

    length = len(graph)

    while len(queue) != 0:

        a = queue.pop(0)
        print(a,end = " ")

        for i in range(length):
            if graph[a][i] == 1 and i not in visited:
                queue.append(i)
                visited.add(i)
    

def main():
    graph = []

    n = int(input("Enter the number of vertices : "))

    print("Enter the adjacency matrix row wise : ")

    for i in range(n):
        row = list(map(int,input().split()))
        graph.append(row)

    print("Enter the starting vertex : ")
    s = int(input())

    print("BFS TRAVERSAL : ")
    bfs(graph,s)

main()    
    

