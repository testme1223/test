from collections import deque

goal = (1,2,3,4,5,6,7,8,0)

def print_board(state):
    for i in range(0,9,3):
        print(state[i:i+3])
    print()
    


def get_next(state):
    res = []
    i = state.index(0)
    x,y = divmod(i,3)    

    for k,l in [(-1,0),(1,0),(0,-1),(0,1)]:
        nx,ny = k +x,l+y
        if 0 <= nx < 3 and  0 <= ny < 3:
            ni = nx*3 + ny
            new = list(state)
            new[i],new[ni] = new[ni],new[i]
            res.append(tuple(new))
    return res
        
def bfs(start):
    q = deque([(start, [start])])
    visited = set([start])
    
    while q :
        state, path = q.popleft()
        
        if state == goal:
            print("Solution found")
            for i in path :
                print_board(i)
            print("Total Steps : ",len(path)-1)
            return
        for i in get_next(state):
            if i not in visited :
                visited.add(i)
                q.append((i,path+[i]))
    print("No Solution")

            
start = tuple(map(int,input("Enter 9 number from 0-8 : ").split()))
bfs(start)





