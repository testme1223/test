def dfs(graph,s):
    
    stack = [s]
    visited = set()
    length = len(graph)
    
    while len(stack) != 0:
        
        a = stack.pop()
        if a not in visited:
            visited.add(a)
            print(a,end=" ")
        
        for i in range(length):
            if graph[a][i] == 1 and i not in visited:
                stack.append(i)

def main():
    graph = []

    print("Enter the number of vertices : ")
    n = int(input())

    print("Enter the adjacency matrix row wise :")
    for i in range(n):
        row = list(map(int,input().split()))
        graph.append(row)

    s = int(input("Enter the starting vertex : "))

    print("DFS TRAVERSAL : ")
    dfs(graph,s)

main()


3.


def tic_tac_toe():
    board = [" "] *9

    def print_board():
        for i in range(0, 9, 3):
            print(board[i:i+3])
    
    def check_win(p):
        wins = [(0,1,2),(3,4,5),(6,7,8),
                (0,3,6),(1,4,7),(2,5,8),
                (0,4,8),(2,4,6)]
        return any(board[a] == board[b] == board[c] == p for a,b,c in wins)


    move = 0
    player = 'X'
    
    while move < 9:
        print_board()
        try :
            move = int(input(player + " move (0-8) : "))
        except:
             print("Enter a number!")
             continue
        
        if move > 8 or move < 0:
             print("Enter between 0 and 8!")
             continue
        
        if board[move] != " ":
            print("Cell already Occupied")
            continue
    
            
        board[move] = player
        move += 1
        
        if (check_win(player)):
            print_board()
            print(player, "wins!")
            return
        
        player = 'O' if player == 'X' else 'X'
        
    

    print_board()
    print("DRAW")
            
tic_tac_toe()

