import math

def ab(d, i, maxP, v, a, b):
    if d == 0:
        return v[i]

    if maxP:
        val = -math.inf
        for j in range(2):
            val = max(val,ab(d-1,i*2+j,False,v,a,b))
            a = max(a,val)
            if a >= b:
                break
        return val
    else :
        val = math.inf
        for j in range(2):
            val = min(val,ab(d-1,i*2+j,True,v,a,b))
            b = min(b,val)
            if a >= b:
                break
        return val
            

 

# --------- Dynamic Input ---------
depth = int(input("Enter depth: "))

n = 2**depth   # number of leaf nodes
values = list(map(int, input(f"Enter {n} leaf values: ").split()))

result = ab(depth, 0, True, values, -math.inf, math.inf)
print("Optimal value:", result)






