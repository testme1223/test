  9.
  arr = []

print "Enter the number of elements : "
n = gets.chomp.to_i
for i in 1..n
  print "Enter Element #{i} : "
  arr << gets.chomp.to_i
end

print arr ,"\n"

arr.push(60)
arr.insert(2,90)
arr.unshift(5)
print arr ,"\n"


a = arr.pop
b = arr.shift
arr.delete(90)
print arr ,"\n"

print "Popped element: ", a ,"\n"
print "Shifted element: ", b ,"\n"


print "Element at index 2: ", arr[2] ,"\n"


arr[1] = 25
print arr ,"\n"


print "Index of 30: ", arr.index(30) ,"\n"
print "Include 50?: ", arr.include?(50) ,"\n"


print "Length: ", arr.length ,"\n"


sorted = arr.sort
print "Sorted: ", sorted ,"\n"


rev = arr.reverse
print "Reversed: ", rev ,"\n"


print "Elements: "
arr.each do |x|
  print x ," "
end
print "\n"


dup = [1,2,2,3,3,4]
print "Unique: ", dup.uniq ,"\n"


arr.clear
print "After clear: ", arr ,"\n"



10.

marks = {}

print "Enter the number of Subjects : "
n = gets.chomp.to_i

for i in 1..n
  print "Enter subject #{i} name : "
  subject = gets.chomp

  print "Enter marks of #{subject}: "
  score = gets.chomp.to_i

  marks[subject] = score
end

puts "Marks : "
print marks,"\n"

total_marks = 0

for score in marks.values 
  total_marks += score
end

print "Total marks : #{total_marks}"

# "Maths" => 85,  
#   "Physics" => 89,  
#   "Chemistry" => 75,  
#   "Biology" => 95,  
#   "IT" => 99  
