from collections import deque

def monkey_banana():
    start = ('Far', 'NotUnder', 'Off', 'Empty')
    goal = ('Near', 'Under', 'On', 'Holding')

    actions = {
        "move" : lambda s : ('Near',s[1],s[2],s[3]) if s[0] != 'Near' else None,
        "push" : lambda s : ('Near','Under',s[2],s[3]) if s[0] == 'Near' and s[1] != 'Under' else None,
        "climb" : lambda s : ('Near','Under','On',s[3]) if s[0] == 'Near' and s[1] == 'Under' and s[2] != 'On' else None,
        "grab" : lambda s : ('Near','Under','On','Holding') if s[0] == 'Near' and s[1] == 'Under' and s[2] == 'On'  and s[3] != 'Holding' else None
        
    }

    q = deque([(start, [])])
    visited = set()

    print("Initial:", start)

    while q:
        state, path = q.popleft()

        if state == goal:
            print("\nSolution Found:")
            for i in path:
                print(i)
            print("\nFinal:", state)
            return

        if state in visited:
            continue
        visited.add(state)

        for name, func in actions.items():
            new = func(state)
            if new and (new not in visited):
                q.append((new, path + ["Action : " + name, "Resulting state : " , new]))

monkey_banana()

