def toh(n,S,A,D):
    
    if n == 1:
        print("Move disk 1 from ",S, " to ",D)
        return
    
    toh(n-1,S,D,A)
    print("Move disk",n,"from ",S, " to ",D)
    toh(n-1,A,S,D)
    
n = int(input("Enter the number of disks : "))

toh(n,'A','B','C')



