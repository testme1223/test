import itertools

def tsp(graph,s):
    
    n = len(graph)
    min_cost = float('inf')
    cities = list(range(n))
    cities.remove(s)
    best_path = []
    
    for i in itertools.permutations(cities):
        path = (s,) + i + (s,)
        cost = 0
    
    for i in range(len(path)-1):
        cost += graph[path[i]][path[i+1]]
    
    if cost < min_cost:
        min_cost = cost
        best_path = path
        
        
    print("Mnimum Cost : ",min_cost)
    print("Best Path : ",best_path)
    

graph = []

n = int(input("Enter the number of vertices : "))

print("Enter the adjacency matrix row wise : ")

for i in range(n):
    row = list(map(int,input().split()))
    graph.append(row)

print("Enter the starting vertex : ")
s = int(input())

tsp(graph,s)



