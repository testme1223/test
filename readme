def dfs(graph,s):
    
    stack = [s]
    visited = set()
    length = len(graph)
    
    while len(stack) != 0:
        
        a = stack.pop()
        if a not in visited:
            visited.add(a)
            print(a,end=" ")
        
        for i in range(length):
            if graph[a][i] == 1 and i not in visited:
                stack.append(i)

def main():
    graph = []

    print("Enter the number of vertices : ")
    n = int(input())

    print("Enter the adjacency matrix row wise :")
    for i in range(n):
        row = list(map(int,input().split()))
        graph.append(row)

    s = int(input("Enter the starting vertex : "))

    print("DFS TRAVERSAL : ")
    dfs(graph,s)

main()


